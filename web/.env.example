# No WalletConnect / RainbowKit required.
# Wallet connect uses browser extensions only (MetaMask, Rabby, Coinbase Wallet extension, etc.)

# Public site URL (used in API links + Bankr skill COMMUNITIES_SITE_URL)
NEXT_PUBLIC_SITE_URL=https://bankr.space

# Vercel Redis — auto-set when you connect Redis in Vercel dashboard
REDIS_URL=

# Optional: Upstash/KV REST (if not using REDIS_URL)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Cron secret — set in Vercel env; Vercel sends this header on cron jobs
CRON_SECRET=

# Pinata — banner/icon upload + IPFS mirroring (optional)
PINATA_JWT=

# x402 platform fundraising (shared endpoint for every space)
NEXT_PUBLIC_X402_FUND_URL=https://x402.bankr.bot/0xYOUR_WALLET/fund
X402_FUND_WEBHOOK_SECRET=
