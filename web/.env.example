# No WalletConnect / RainbowKit required.
# Wallet connect uses browser extensions only (MetaMask, Rabby, Coinbase Wallet extension, etc.)

# Public site URL (used in API links + Bankr skill COMMUNITIES_SITE_URL)
NEXT_PUBLIC_SITE_URL=https://bankr.space

# Vercel Redis — auto-set when you connect Redis in Vercel dashboard
REDIS_URL=

# Optional: Upstash/KV REST (if not using REDIS_URL)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Cron secret — set in Vercel env; Vercel sends this header on cron jobs
CRON_SECRET=

# Pinata — banner/icon upload + IPFS mirroring (optional)
PINATA_JWT=

# x402 fundraising — host/template; per-space URL uses fee recipient wallet (never deployer)
NEXT_PUBLIC_X402_FUND_URL=https://x402.bankr.bot/0xFEE_RECIPIENT_WALLET/fund
# Lane B community agent pool — optional override when platform-agent x402 path 404s
# NEXT_PUBLIC_X402_AGENT_POOL_FUND_URL=https://x402.bankr.bot/0xYOUR_DEPLOYED_X402_WALLET/fund
# Optional override host only: NEXT_PUBLIC_X402_FUND_HOST=https://x402.bankr.bot
X402_FUND_WEBHOOK_SECRET=

# Bankr Space platform agent — dedicated Base Account (NOT @bankrbot)
# Create: aeon-skill-pack/BASE-ACCOUNT-SETUP.md → Base MCP get_wallets
PLATFORM_AGENT_WALLET=
# POIDH open bounties — dedicated EOA (MetaMask/Rabby hot wallet, NOT Base Account)
# Funds createOpenBounty, acceptClaim, and submitClaimForVote. ~0.001 ETH seed per bounty + gas.
POIDH_ISSUER_WALLET=
POIDH_ISSUER_PRIVATE_KEY=
# Base RPC — required for production (POIDH server + browser wallet reads)
# Public mainnet.base.org rate-limits quickly during x402 Contribute (Permit2 allowance checks).
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
NEXT_PUBLIC_BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
# Bankr Agent API key for platform wallet — executes funded 0xWork/QRCoin pool goals (Vercel cron)
# Same bk_… key as Aeon BANKR_API_KEY. Falls back to BANKR_API_KEY if unset.
PLATFORM_AGENT_BANKR_API_KEY=
# Show "Use Bankr Space Agent" on space pages (set true when Aeon worker is live)
# NEXT_PUBLIC_PLATFORM_AGENT_UI=true

# Token Marketplace petition API (Base pre-launch spaces)
TMP_PETITION_API_BASE=https://www.tokenmarketplace.shop/api/petition

SITE_ADMIN_WALLET=0xbFF8c6C34f1EFacF6844350dE907Cca6F07C76b8

# Telegram Bot — create via @BotFather on Telegram
# 1. /newbot → copy token below
# 2. After deploy: curl https://www.bankr.space/api/telegram/setup to register webhook
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=bankrspacebot
# Secret token Telegram sends on every webhook request (set in setWebhook call)
TELEGRAM_WEBHOOK_SECRET=
# Internal secret for bot → /api/telegram/link (any random string)
TELEGRAM_INTERNAL_SECRET=
