{
  "framework": "nextjs",
  "buildCommand": "next build",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/sync-tokens",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/agent-pool-verify",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/agent-pool-worker",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/poidh-bounties",
      "schedule": "*/10 * * * *"
    }
  ]
}
