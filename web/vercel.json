{
  "framework": "nextjs",
  "buildCommand": "next build",
  "installCommand": "npm install",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors *"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/sync-tokens",
      "schedule": "0 * * * *"
    }
  ]
}
