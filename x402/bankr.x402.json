{
  "network": "base",
  "currency": "USDC",
  "services": {
    "fund": {
      "description": "Contribute USDC to a Bankr community fundraiser",
      "price": "1",
      "methods": ["GET"],
      "category": "payments",
      "tags": ["fundraiser", "community", "bankr"],
      "schema": {
        "input": {
          "type": "object",
          "properties": {
            "token": {
              "type": "string",
              "description": "Community token contract address (0x...)"
            },
            "campaign": {
              "type": "string",
              "description": "Campaign id: dex-profile | dex-boost | custom",
              "enum": ["dex-profile", "dex-boost", "custom"]
            },
            "amount": {
              "type": "string",
              "description": "Contribution amount in USD (USDC)"
            }
          },
          "required": ["token", "campaign", "amount"]
        },
        "output": {
          "type": "object",
          "properties": {
            "success": { "type": "boolean" },
            "token": { "type": "string" },
            "campaignId": { "type": "string" },
            "raisedUsd": { "type": "number" },
            "goalUsd": { "type": "number" }
          }
        }
      }
    }
  }
}
