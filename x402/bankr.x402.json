{
  "network": "base",
  "currency": "Space",
  "services": {
    "fund": {
      "description": "Contribute Bankr Space ($Space) to a community fundraiser on bankr.space",
      "price": "250000",
      "tokenAddress": "0xef703b860a6d422fa00cc67bbbb2662297cb6ba3",
      "paymentScheme": "upto",
      "methods": ["GET"],
      "category": "payments",
      "tags": ["fundraiser", "community", "bankr", "space"],
      "schema": {
        "input": {
          "type": "object",
          "properties": {
            "token": {
              "type": "string",
              "description": "Community token contract address (0x...) — which space gets credit"
            },
            "campaign": {
              "type": "string",
              "description": "Campaign id: dex-profile | dex-boost | custom | agent-qrcoin | agent-0xwork",
              "enum": ["dex-profile", "dex-boost", "custom", "agent-qrcoin", "agent-0xwork"]
            },
            "amount": {
              "type": "string",
              "description": "USD credit amount toward the goal (display)"
            }
          },
          "required": ["token", "campaign", "amount"]
        },
        "output": {
          "type": "object",
          "properties": {
            "success": { "type": "boolean" },
            "token": { "type": "string" },
            "campaignId": { "type": "string" },
            "raisedUsd": { "type": "number" },
            "goalUsd": { "type": "number" }
          }
        }
      }
    }
  }
}
